# ============================================================
#  환경변수 예시 — 이 파일을 복사해서 .env.local 로 만들고 값을 채우세요.
#  (.env.local 은 git에 올라가지 않습니다)
#  Vercel 배포 시에는 같은 값을 Vercel → Settings → Environment Variables 에 등록.
# ============================================================

# ── Supabase (행동 추적 DB) ──
# Supabase 프로젝트 → Settings → API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# ⚠️ service_role 키(secret). 절대 외부에 노출 금지. 서버에서만 사용됨.
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key...

# ── 관리자 대시보드(/admin) 비밀번호 ──
# 원하는 비밀번호를 직접 정하세요.
ADMIN_PASSWORD=원하는비밀번호

# 상담신청 → 구글 시트는 "구글 폼 방식"이라 환경변수가 필요 없습니다.
# (google-sheet-연동.md 참고)
